{
    /* Upon filename change UPDATE all "PanelManager", "GameplayOptionsPanel", "SettingsPanel" entries to filename without the "hd" ending */
    "type": "GameplayOptionsPanel",
    "name": "modinfo_generalinformation",
    "fields": {
        "priority": 9003,
        "rect": "$OptionsPanelRect",
        "anchor": {
            "x": 0.5
        },
        "applySettingsImmediately": false
    },
    "children": [
        {
            "type": "ImageWidget",
            "name": "ScrollBarBackground",
            "fields": {
                "rect": "$OptionsScrollBarBackgroundRect",
                "anchor": {
                    "x": 1.0
                },
                "filename": "PauseMenu\\VerticalScroll"
            },
            "children": [
                {
                    "type": "ScrollControllerWidget",
                    "name": "ScrollController",
                    "fields": {
                        "rect": "$OptionsScrollBarRect",
                        "anchor": {
                            "x": 1.0
                        },
                        "upArrowFilepath": "FrontEnd\\HD\\Final\\FrontEnd_ScrollUpBtn",
                        "downArrowFilepath": "FrontEnd\\HD\\Final\\FrontEnd_ScrollDownBtn",
                        "barFilepath": "PauseMenu\\VerticalIndicator",
                        "viewName": "ScrollView",
                        "wheelScrollSound": "cursor_scroll_hd",
                        "buttonScrollSound": "cursor_scroll_hd"
                    }
                }
            ]
        },
        {
            "type": "ScrollViewWidget",
            "name": "ScrollView",
            "fields": {
                "fitToParent": true,
                "scrollControllerName": "ScrollController"
            },
            "children": [
                {
                    "type": "TableWidget",
                    "name": "OptionsTable",
                    "fields": {
                        "columns": [
                            "$OptionsTableColumn1",
                            "$OptionsTableColumn2"
                        ],
                        "rowHeight": "$OptionsTableRowHeight"
                    },
                    "children": [
                        /* >>> WEBSITE TITLE >>> */
                        {
                            "type": "TableRowWidget",
                            "name": "Upgrading",
                            "children": [
                                {
                                    "type": "TextBoxWidget",
                                    "name": "Upgrading",
                                    "fields": {
                                        "text": "@strWebWikiHead",
                                        "style": "$StyleSettingsTitle"
                                    },
                                    "children": [
                                        {
                                            "type": "ImageWidget",
                                            "name": "Divider",
                                            "fields": {
                                                "rect": "$OptionsDividerRect",
                                                "filename": "PauseMenu\\Divider"
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        /* >>> WEBSITE LINK BELOW >>> */
                        {
                            "type": "TableRowWidget",
                            "name": "RowTab",
                            "fields": {
                                "rect": {
                                    "height": 350
                                }
                            },
                            "children": [
                                {
                                    "type": "TextBoxWidget",
                                    "name": "TextBox",
                                    "fields": {
                                        "text": "@strWebWikiBody",
                                        "style": {
                                            "pointSize": 28,
                                            "spacing": {
                                                "leading": 0.95,
                                                "kerning": 0.95
                                            },
                                            "alignment": {
                                                "h": "left",
                                                "v": "center"
                                            },
                                            "options": {
                                                "lineWrap": true,
                                                "newlineHandling": "standard",
                                                "pipeCharacterBehavior": "handle"
                                            }
                                        }
                                    }
                                }
                            ]
                        },
                        /* <<< WEBSITE LINK OVER <<< */
                        /* >>> GENERAL CHANGES TITLE >>> */
                        {
                            "type": "TableRowWidget",
                            "name": "Upgrading",
                            "children": [
                                {
                                    "type": "TextBoxWidget",
                                    "name": "Upgrading",
                                    "fields": {
                                        "text": "@strGCHead",
                                        "style": "$StyleSettingsTitle"
                                    },
                                    "children": [
                                        {
                                            "type": "ImageWidget",
                                            "name": "Divider",
                                            "fields": {
                                                "rect": "$OptionsDividerRect",
                                                "filename": "PauseMenu\\Divider"
                                            }
                                        }
                                    ]
                                }
                            ]
